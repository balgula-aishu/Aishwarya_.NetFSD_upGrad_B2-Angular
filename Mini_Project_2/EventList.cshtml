@model IEnumerable<UVEMS.DAL.Models.EventDetails>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Explore Events";
}

<!-- HEADER -->
<h2 class="text-center mb-5 text-gradient fade-in">
    <i class="fa-solid fa-compass me-2"></i> Explore Events
</h2>

<!-- EVENTS -->
<div class="row g-4 fade-in">

    @foreach (var e in Model)
    {
        <div class="col-md-4">

            <!-- HOME-STYLE EVENT CARD -->
            <div class="event-card h-100 d-flex flex-column justify-content-between">

                <!-- EVENT INFO -->
                <div>

                    <h4 class="fw-bold text-white mb-2">
                        @e.EventName
                    </h4>

                    <p class="text-muted-custom mb-1">
                        <i class="fa fa-layer-group text-info me-1"></i>
                        @e.EventCategory
                    </p>

                    <p class="text-muted-custom mb-2">
                        <i class="fa fa-calendar-days text-warning me-1"></i>
                        @e.EventDate.ToShortDateString()
                    </p>

                    <p style="color:#cbd5e1; font-size:14px;">
                        @(string.IsNullOrEmpty(e.Description)
                                            ? "No description available"
                                            : e.Description)
                    </p>

                </div>

                <!-- ACTION BUTTONS -->
                <div class="mt-3 d-flex gap-2">

                    <!-- VIEW SESSIONS (DIFFERENT STYLE - ORANGE/YELLOW) -->
                    <div class="mt-3 d-flex gap-2">

                        <a asp-action="Sessions"
                           asp-route-eventId="@e.EventId"
                           class="btn btn-custom w-50">
                            View Sessions
                        </a>

                        <a asp-action="Register"
                           asp-route-eventId="@e.EventId"
                           class="btn btn-outline-info w-50">
                            Register
                        </a>

                    </div>
                </div>

            </div>

        </div>
    }

</div>

<!-- EMPTY STATE -->
@if (!Model.Any())
{
    <div class="text-center mt-5 fade-in">

        <h5>No events available</h5>
        <p class="text-muted-custom">
            Please check back later.
        </p>

    </div>
}