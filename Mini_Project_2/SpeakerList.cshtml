@model IEnumerable<UVEMS.DAL.Models.SpeakerDetails>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Speakers";
}

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4 fade-in">

    <div>
        <h2 class="text-gradient mb-1">
            <i class="fa fa-microphone-lines me-2"></i> Speakers
        </h2>
        <p class="text-muted-custom">
            Manage and organize event speakers efficiently
        </p>
    </div>

    <!-- SKY BLUE ADD BUTTON -->
    <a asp-action="AddSpeaker"
       class="btn"
       style="
            background: linear-gradient(45deg, #00eaff, #0072ff);
            color: white;
            font-weight: 500;
            border-radius: 10px;
            padding: 10px 16px;
       ">
        <i class="fa fa-plus"></i> Add Speaker
    </a>

</div>

<!-- SPEAKER CARDS (HOME STYLE) -->
<div class="row g-4">

    @foreach (var sp in Model)
    {
        <div class="col-md-4 fade-in">

            <div class="event-card h-100 d-flex flex-column justify-content-between text-center"
                 style="transition:0.3s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.5)'"
                 onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">

                <!-- TOP CONTENT -->
                <div>

                    <div class="mb-3">
                        <div class="icon-box bg-info">
                            <i class="fa fa-user-tie"></i>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 text-white">
                        @sp.SpeakerName
                    </h5>

                </div>

                <!-- ACTION -->
                <div>

                    <!-- SMALL RED DELETE BUTTON -->
                    <a asp-action="DeleteSpeaker"
                       asp-route-id="@sp.SpeakerId"
                       class="btn btn-sm w-100"
                       style="
                                background: rgba(255,0,0,0.15);
                                border: 1px solid rgba(255,0,0,0.4);
                                color: #ff4d4d;
                                border-radius: 10px;
                           ">
                        <i class="fa fa-trash me-1"></i> Delete
                    </a>

                </div>

            </div>

        </div>
    }

</div>

<!-- EMPTY STATE -->
@if (!Model.Any())
{
    <div class="text-center mt-5 fade-in">

        <i class="fa fa-microphone-slash fa-2x mb-3 text-muted-custom"></i>

        <h5>No Speakers Available</h5>

        <p class="text-muted-custom">
            Start by adding speakers for your sessions
        </p>

        <a asp-action="AddSpeaker"
           class="btn mt-2"
           style="
                    background: linear-gradient(45deg, #00eaff, #0072ff);
                    color: white;
                    font-weight: 500;
                    border-radius: 10px;
                    padding: 10px 16px;
               ">
            <i class="fa fa-plus"></i> Add Speaker
        </a>

    </div>
}