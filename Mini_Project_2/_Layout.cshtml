<!DOCTYPE html>
<html>
<head>
    <title>UVEMS</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark px-3">

        <a class="navbar-brand fw-bold text-info" href="/Common/Home">
            <i class="fa-solid fa-bolt"></i> UVEMS
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">

            <!-- LEFT MENU -->
            <ul class="navbar-nav me-auto">

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Home" ? "active text-info fw-bold" : "")"
                       href="/Common/Home">
                        <i class="fa fa-house"></i> Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Participant/EventList">
                        <i class="fa fa-compass"></i> Explore
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active text-info fw-bold" : "")"
                       href="/Common/About">
                        <i class="fa fa-circle-info"></i> About
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active text-info fw-bold" : "")"
                       href="/Common/Contact">
                        <i class="fa fa-envelope"></i> Contact
                    </a>
                </li>

            </ul>

            <!-- RIGHT MENU -->
            <ul class="navbar-nav">

                <!-- LOGIN -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="fa fa-user"></i> Login
                    </a>

                    <ul class="dropdown-menu dropdown-menu-dark">

                        <li>
                            <a class="dropdown-item" href="/Common/AdminLogin">
                                <i class="fa fa-user-shield"></i> Admin
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/Common/ParticipantLogin">
                                <i class="fa fa-user"></i> Participant
                            </a>
                        </li>

                    </ul>
                </li>

                <!-- REGISTER -->
                <li class="nav-item">
                    <a class="nav-link" href="/Common/Register">
                        <i class="fa fa-user-plus"></i> Register
                    </a>
                </li>

                <!-- LOGOUT -->
                <li class="nav-item">
                    <a class="nav-link text-danger" href="/Common/Logout">
                        <i class="fa fa-right-from-bracket"></i> Logout
                    </a>
                </li>

            </ul>

        </div>

    </nav>

    <!-- PAGE CONTENT WRAPPER -->
    <div class="main-wrapper">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="text-center text-muted py-3 mt-5"
            style="border-top: 1px solid rgba(255,255,255,0.1);">

        © 2026 UVEMS | Modern Event Management Platform

    </footer>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>