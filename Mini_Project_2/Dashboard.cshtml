@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Participant Dashboard";
}

<div class="text-center mb-5 fade-in">

    <h1 class="text-gradient">Welcome to UVEMS</h1>

    <p class="text-muted-custom">
        Explore events, sessions and manage participation
    </p>

</div>

<div class="row justify-content-center g-4">

    <div class="col-md-4">
        <div class="event-card text-center h-100">

            <div class="icon-box bg-info">
                <i class="fa fa-compass"></i>
            </div>

            <h4 class="mt-3 text-black">Explore Events</h4>

            <a href="/Participant/EventList"
               class="btn btn-custom w-100 mt-3">
                Explore
            </a>

        </div>
    </div>

    <div class="col-md-4">
        <div class="event-card text-center h-100">

            <div class="icon-box bg-success">
                <i class="fa fa-list-check"></i>
            </div>

            <h4 class="mt-3 text-black">My Events</h4>

            <a href="/Participant/MyEvents"
               class="btn btn-custom w-100 mt-3">
                View
            </a>

        </div>
    </div>

</div>