<!DOCTYPE html>
<html>
<head>
    <title>Participant Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #ff9966, #ff5e62);
            color: white;
        }

        .navbar {
            background: rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
        }

        .card {
            border-radius: 15px;
            transition: 0.3s;
        }

        .card:hover {
            transform: scale(1.05);
        }

        .btn-custom {
            background: #00c6ff;
            border: none;
            color: white;
        }

        .btn-custom:hover {
            background: #0072ff;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <a class="navbar-brand fw-bold">EMS Participant</a>

        <div class="ms-auto">
            <a href="/Participant/MyEvents" class="btn btn-light me-2">My Events</a>
            <a href="/Common/Logout" class="btn btn-dark">Logout</a>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>
