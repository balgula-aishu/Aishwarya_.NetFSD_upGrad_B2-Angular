@model UVEMS.DAL.Models.SpeakerDetails
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Add Speaker";
}

<div class="mb-5 fade-in text-center">

    <h2 class="text-gradient mb-2">
        <i class="fa fa-microphone-lines me-2"></i> Add Speaker
    </h2>

    <p class="text-muted-custom">
        Add speaker details for event sessions
    </p>

</div>

<div class="card center-card mx-auto fade-in" style="max-width:600px;">

    <form asp-action="AddSpeaker" method="post">

        <!-- SPEAKER NAME -->
        <div class="mb-3">

            <label class="form-label text-white">
                <i class="fa fa-user me-1"></i> Speaker Name
            </label>

            <!-- ✅ FIXED INPUT -->
            <input asp-for="SpeakerName"
                   class="form-control custom-input fixed-input form-control-sm"
                   style="color:black !important; background:white !important;"
                   placeholder="Enter speaker name" />

            <span asp-validation-for="SpeakerName" class="text-danger"></span>

        </div>

        <!-- ACTION BUTTONS -->
        <div class="d-flex justify-content-between align-items-center mt-4">

            <a href="/Admin/SpeakerList"
               class="btn btn-outline-light btn-sm px-3"
               style="border:1px solid rgba(255,255,255,0.3);">

                <i class="fa fa-arrow-left me-1"></i> Back

            </a>

            <!-- ✅ FIXED BUTTON STYLE -->
            <button type="submit"
                    class="btn btn-sky btn-sm px-4"
                    style="
                    background: linear-gradient(45deg, #00eaff, #0072ff);
                    color: white;
                    font-weight: 500;
                    border-radius: 10px;
                    ">

                <i class="fa fa-plus me-1"></i> Add Speaker

            </button>

        </div>

    </form>

</div>

