@model UVEMS.DAL.Models.EventDetails
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Edit Event";
}

<!-- HEADER -->
<div class="mb-5 fade-in text-center">

    <h2 class="text-gradient mb-2">
        <i class="fa fa-pen me-2"></i> Edit Event
    </h2>

    <p class="text-muted-custom">
        Update event details and manage information
    </p>

</div>

<!-- FORM CARD -->
<div class="center-card mx-auto fade-in" style="max-width:750px;">

    <form asp-action="EditEvent" method="post">

        <input type="hidden" asp-for="EventId" />

        <div class="row g-3">

            <!-- EVENT NAME -->
            <div class="col-md-6">
                <label class="form-label text-white">Event Name</label>

                <input asp-for="EventName"
                       class="form-control custom-input form-control-sm" 
                       style="color:white !important;"
                       value="@Model.EventName"
                       placeholder="Enter event name" />
            </div>

            <!-- CATEGORY -->
            <div class="col-md-6">
                <label class="form-label text-white">Category</label>

                <input asp-for="EventCategory"
                       class="form-control custom-input form-control-sm"
                       style="color:white !important;"
                       value="@Model.EventCategory"
                       placeholder="Enter category" />
            </div>

            <!-- DATE -->
            <div class="col-md-6">
                <label class="form-label text-white">Event Date</label>

                <input asp-for="EventDate"
                       type="date"
                       class="form-control custom-input form-control-sm"
                       style="color:white !important;" />
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label class="form-label text-white">Status</label>

                <select asp-for="Status"
                        class="form-control custom-input form-control-sm"
                        style="background: rgba(15,23,42,0.9); color:black">

                    <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                    <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>

                </select>
            </div>

            <!-- DESCRIPTION -->
            <div class="col-12">
                <label class="form-label text-white">Description</label>

                <textarea asp-for="Description"
                          class="form-control custom-input"
                          style="color:black !important;"
                          rows="3"
                          placeholder="Update event description...">@Model.Description</textarea>
            </div>

        </div>

        <!-- BUTTONS -->
        <div class="d-flex justify-content-between align-items-center mt-4">

            <a href="/Admin/EventList"
               class="btn btn-outline-light btn-sm px-4"
               style="border:1px solid rgba(255,255,255,0.3);">
                <i class="fa fa-arrow-left me-1"></i> Back
            </a>

            <button type="submit"
                    class="btn btn-sm px-5"
                    style="
                        background: linear-gradient(45deg, #00eaff, #0072ff);
                        color: white;
                        border-radius: 10px;
                        font-weight: 500;
                    ">
                <i class="fa fa-save me-1"></i> Update Event
            </button>

        </div>

    </form>

</div>
