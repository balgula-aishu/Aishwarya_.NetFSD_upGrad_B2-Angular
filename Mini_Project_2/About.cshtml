@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "About";
}

<div class="text-center mb-5 fade-in">

    <h2 class="text-gradient">
        <i class="fa fa-circle-info me-2"></i> About UVEMS
    </h2>

    <p class="text-muted-custom" style="max-width:700px; margin:auto;">
        UVEMS (Upgraded Virtual Event Management System) is a modern platform designed to simplify event management and enhance user experience.
    </p>

</div>

<div class="card p-4 fade-in">

    <h4 class="text-white mb-3">What is UVEMS?</h4>
    <p class="text-white">
        UVEMS allows organizers to create and manage events, schedule sessions, and track participants efficiently.
        Users can explore events, register, and attend sessions seamlessly.
    </p>

    <h4 class="text-white mt-4 mb-3">Key Features</h4>
    <ul class="text-white">
        <li>Event Creation and Management</li>
        <li>Session Scheduling</li>
        <li>User Registration</li>
        <li>Role-based Access Control</li>
        <li>Modern Responsive UI</li>
    </ul>

    <h4 class="text-white mt-4 mb-3">Our Mission</h4>
    <p class="text-white">
        To provide a smooth and efficient platform for managing events digitally with a modern and user-friendly interface.
    </p>

</div>