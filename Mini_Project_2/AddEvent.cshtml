@model UVEMS.DAL.Models.EventDetails
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Add Event";
}

<!-- HEADER -->
<div class="mb-5 fade-in text-center">

    <h2 class="text-gradient mb-2">
        <i class="fa fa-calendar-plus me-2"></i> Add New Event
    </h2>

    <p class="text-muted-custom">
        Create and manage event details easily
    </p>

</div>

<!-- FORM CARD (LOGIN STYLE) -->
<div class="center-card mx-auto fade-in" style="max-width:750px;">

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            <i class="fa fa-exclamation-circle"></i> @ViewBag.Error
        </div>
    }

    <form asp-action="AddEvent" method="post">

        <div class="row g-3">

            <!-- EVENT NAME -->
            <div class="col-md-6">
                <label class="form-label text-white mb-1">
                    Event Name
                </label>

                <input asp-for="EventName"
                       class="form-control custom-input fixed-input"
                       style="color:black !important; background:white !important;"
                       placeholder="Enter event name" />
            </div>

            <!-- CATEGORY -->
            <div class="col-md-6">
                <label class="form-label text-white mb-1">
                    Category
                </label>

                <input asp-for="EventCategory"
                       class="form-control custom-input fixed-input text-black"
                       style="color:black !important; background:white !important;"
                       placeholder="Enter category" />
            </div>

            <!-- DATE -->
            <div class="col-md-6">
                <label class="form-label text-white mb-1">
                    Event Date
                </label>
                <input asp-for="EventDate"
                       type="date"
                       class="form-control custom-input fixed-input"
                       value="@(Model.EventDate != DateTime.MinValue ? Model.EventDate.ToString("yyyy-MM-dd") : "")" />
               
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label class="form-label text-white mb-1">
                    Status
                </label>

                <select asp-for="Status"
                        class="form-control custom-input fixed-input "
                        style="color:black !important; background:white !important;">

                    <option value="">-- Select Status --</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>

                </select>
            </div>

            <!-- DESCRIPTION -->
            <div class="col-12">
                <label class="form-label text-white mb-1">
                    Description
                </label>

                <textarea asp-for="Description"
                          class="form-control custom-input fixed-input text-black"
                          style="color:black !important; background:white !important;"
                          rows="3"
                          placeholder="Write event description..."></textarea>
            </div>

        </div>

        <!-- ACTION BUTTONS -->
        <div class="d-flex justify-content-between align-items-center mt-4">

            <a href="/Admin/EventList"
               class="btn btn-outline-light px-4">
                <i class="fa fa-arrow-left me-1"></i> Back
            </a>

            <!-- SKY BLUE SAVE BUTTON -->
            <button type="submit"
                    class="btn btn-custom px-5">
                <i class="fa fa-save me-1"></i> Save Event
            </button>

        </div>

    </form>

</div>
